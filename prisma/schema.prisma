generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model AuditSnapshot {
  id            String   @id @default(uuid())
  batchId       String
  agence        String
  mode          String
  scoreGlobal   Float
  niveau        String
  nbAnomalies   Int
  totalPenalite Float
  metrics       Json?
  sectionNotes  Json?
  snapshot      Json
  createdAt     DateTime @default(now())

  @@index([batchId])
  @@index([agence, mode])
  @@index([createdAt])
}
